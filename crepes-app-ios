<body>

<div aria-live="polite" class="sr-only" id="live-region"></div>

<header>
  <span class="badge-eyebrow">Recette adaptée de Marmiton</span>
  <h1>Ajusteur de<br><span class="accent">crêpes</span></h1>
  <p class="subtitle">Le nombre d'œufs pilote toute la recette.</p>
</header>

<main class="container">

  <div class="col-left">
    <!-- ==== INPUT ==== -->
    <section class="card egg-hero" aria-labelledby="input-title">
      <span class="egg-word" id="input-title">Nombre d'œufs</span>
      <div class="egg-count-display" id="egg-display" aria-hidden="true">3</div>

      <div class="stepper-row" role="group" aria-label="Ajuster le nombre d'œufs">
        <button class="step-btn" id="btn-minus" type="button" aria-label="Diminuer">−</button>
        <input id="eggs-input" type="number" inputmode="numeric" min="1" max="30" value="3"
               aria-describedby="hint err">
        <button class="step-btn" id="btn-plus" type="button" aria-label="Augmenter">+</button>
      </div>

      <p class="input-hint" id="hint">Entier positif · Ex : 2, 4, 6 · Max 30</p>
      <p class="error-msg" id="err" role="alert"></p>

      <div class="meta-row">
        <div class="meta-chip">Facteur<strong id="factor-chip">×1,00</strong></div>
        <div class="meta-chip">≈ Crêpes<strong id="crepes-chip">12</strong></div>
      </div>

      <button class="reset-btn" id="reset-btn" type="button">↩ Réinitialiser (3 œufs)</button>
    </section>

    <!-- ==== INGREDIENTS ==== -->
    <section class="card" aria-labelledby="ing-title">
      <p class="card-title" id="ing-title">🧾 Ingrédients</p>
      <div class="ing-list" id="ing-list"></div>
      <div class="invalid-overlay" id="invalid-overlay">
        <span style="font-size:1.8rem">⚠️</span><br>Entrez un nombre d'œufs valide pour voir les quantités.
      </div>
    </section>
  </div>

  <div class="col-right">
    <!-- ==== INSTRUCTIONS ==== -->
    <section class="card" aria-labelledby="prep-title">
      <p class="card-title" id="prep-title">👩‍🍳 Préparation</p>
      <ol class="steps">
        <li>Versez la farine dans un grand saladier, creusez un puits. Ajoutez sucre et sel.</li>
        <li>Cassez les œufs au centre et mélangez doucement du centre vers les bords.</li>
        <li>Versez le lait progressivement en fouettant pour éviter les grumeaux, puis incorporez le beurre fondu refroidi.</li>
        <li>Pâte grumeleuse ? Un coup de mixeur ou de tamis et c'est réglé.</li>
        <li><strong>Repos :</strong> 30 min minimum au frais (1 h idéalement). Les crêpes n'en seront que plus souples.</li>
        <li>Poêle bien chaude, légèrement beurrée. Une louche, un geste circulaire pour étaler finement.</li>
        <li>1 à 2 min par face : dès que les bords se décollent, on retourne. 30 s de l'autre côté.</li>
      </ol>
    </section>

    <!-- ==== TIPS ==== -->
    <section class="card" aria-labelledby="tips-title">
      <p class="card-title" id="tips-title">💡 Conseils</p>
      <div class="tips-grid">
        <div class="tip">
          <div class="tip-label">🥣 Trop épaisse</div>
          Un filet de lait, cuillère par cuillère, en mélangeant entre chaque ajout.
        </div>
        <div class="tip">
          <div class="tip-label">💧 Trop liquide</div>
          Une c. à soupe de farine, fouettez fort, puis 10 min de repos supplémentaire.
        </div>
        <div class="tip">
          <div class="tip-label">🌿 Version végétale</div>
          Lait d'avoine ou d'amande en remplacement 1:1. Texture légèrement différente, tout aussi bonne.
        </div>
        <div class="tip">
          <div class="tip-label">⏰ Le repos, c'est la clé</div>
          Le gluten se détend : crêpes plus moelleuses qui se retournent sans se déchirer.
        </div>
      </div>
    </section>
  </div>
</main>

<footer>
  Quantités de base : Marmiton « Crêpes de base » · Texte original · Aucune donnée collectée<br>
  💡 Sur iPhone : Partager → « Sur l'écran d'accueil » pour l'installer comme une app
</footer>

<script>
/* ============================================================
   DATA — Recette de référence (Marmiton, « Crêpes de base », 3 œufs)
   ============================================================ */
const RECIPE = {
  baseEggs: 3,
  crepesPerBase: 12, // ~12 crêpes pour la recette de base
  ingredients: [
    { id: 'flour',  icon: '🌾', name: 'Farine',       baseQty: 250, unit: 'g',  roundTo: 5, type: 'weight' },
    { id: 'milk',   icon: '🥛', name: 'Lait',          baseQty: 500, unit: 'ml', roundTo: 5, type: 'liquid' },
    { id: 'eggs',   icon: '🥚', name: 'Œufs',          baseQty: 3,   unit: '',   roundTo: 1, type: 'count'  },
    { id: 'butter', icon: '🧈', name: 'Beurre fondu',  baseQty: 30,  unit: 'g',  roundTo: 5, type: 'weight' },
    { id: 'sugar',  icon: '🍬', name: 'Sucre',         baseQty: 15,  unit: 'g',  roundTo: 5, type: 'weight' },
    { id: 'salt',   icon: '🧂', name: 'Sel',           baseQty: 1,   unit: null, roundTo: 1, type: 'salt'   },
  ]
};

/* ============================================================
   FONCTIONS PURES (testables)
   ============================================================ */
const roundToNearest = (v, m) => m > 0 ? Math.round(v / m) * m : v;

function computeRecipe(eggCount) {
  if (!Number.isInteger(eggCount) || eggCount < 1) return null;
  const factor = eggCount / RECIPE.baseEggs;
  const items = RECIPE.ingredients.map(ing => {
    let qty, unit;
    if (ing.type === 'count') {
      qty = eggCount; unit = '';
    } else if (ing.type === 'salt') {
      qty = Math.max(1, Math.round(ing.baseQty * factor));
      unit = qty === 1 ? 'pincée' : 'pincées';
    } else {
      qty = Math.max(ing.roundTo, roundToNearest(ing.baseQty * factor, ing.roundTo));
      unit = ing.unit;
    }
    return { ...ing, qty, unit };
  });
  return { factor, items, crepes: Math.round(RECIPE.crepesPerBase * factor) };
}

function validateInput(raw) {
  const t = String(raw).trim();
  if (t === '') return { valid: false, msg: "Veuillez entrer un nombre d'œufs." };
  const n = Number(t);
  if (!Number.isFinite(n)) return { valid: false, msg: 'Valeur non numérique.' };
  if (!Number.isInteger(n)) return { valid: false, msg: 'Entrez un entier (ex : 2, 4, 6).' };
  if (n < 1) return { valid: false, msg: 'Minimum : 1 œuf.' };
  if (n > 30) return { valid: false, msg: 'Maximum : 30 œufs.' };
  return { valid: true, value: n };
}

/* ============================================================
   RENDER
   ============================================================ */
const $ = id => document.getElementById(id);
const ingList = $('ing-list'), overlay = $('invalid-overlay'),
      factorChip = $('factor-chip'), crepesChip = $('crepes-chip'),
      eggDisplay = $('egg-display'), live = $('live-region');
let prev = {};

function render(result) {
  if (!result) {
    ingList.style.display = 'none';
    overlay.classList.add('visible');
    factorChip.textContent = '—';
    crepesChip.textContent = '—';
    eggDisplay.textContent = '?';
    return;
  }
  overlay.classList.remove('visible');
  ingList.style.display = 'flex';

  const eggs = result.items.find(i => i.id === 'eggs').qty;
  eggDisplay.textContent = eggs;
  eggDisplay.classList.remove('pop'); void eggDisplay.offsetWidth; eggDisplay.classList.add('pop');

  factorChip.textContent = '×' + result.factor.toFixed(2).replace('.', ',');
  crepesChip.textContent = result.crepes;

  ingList.innerHTML = result.items.map(it => {
    const changed = prev[it.id] !== undefined && prev[it.id] !== it.qty;
    const u = it.unit ? `<span class="unit"> ${it.unit}</span>` : '';
    return `<div class="ing-row ${changed ? 'updated' : ''}">
      <span class="ing-name"><span class="ing-icon" aria-hidden="true">${it.icon}</span>${it.name}</span>
      <span class="ing-qty">${it.qty}${u}</span>
    </div>`;
  }).join('');

  result.items.forEach(it => prev[it.id] = it.qty);
  setTimeout(() => document.querySelectorAll('.ing-row.updated')
    .forEach(el => el.classList.remove('updated')), 700);

  live.textContent = `Recette pour ${eggs} œufs, environ ${result.crepes} crêpes.`;
}

/* ============================================================
   CONTROLLER
   ============================================================ */
const input = $('eggs-input'), err = $('err');
let timer = null;

function update(raw) {
  const v = validateInput(raw);
  if (!v.valid) {
    input.classList.add('invalid');
    err.textContent = v.msg;
    err.classList.add('visible');
    render(null);
    return;
  }
  input.classList.remove('invalid');
  err.classList.remove('visible');
  render(computeRecipe(v.value));
}

input.addEventListener('input', () => {
  clearTimeout(timer);
  timer = setTimeout(() => update(input.value), 120);
});

$('btn-plus').addEventListener('click', () => {
  const n = Math.min(30, (parseInt(input.value, 10) || 0) + 1);
  input.value = n; update(n);
});

$('btn-minus').addEventListener('click', () => {
  const n = Math.max(1, (parseInt(input.value, 10) || 2) - 1);
  input.value = n; update(n);
});

$('reset-btn').addEventListener('click', () => {
